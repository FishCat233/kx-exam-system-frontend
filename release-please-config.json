{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-v-in-tag": true,
  "include-v-in-release-name": true,
  "pull-request-title-pattern": "Release ${version}",
  "group-pull-request-title-pattern": "Release ${version}",
  "changelog-sections": [
    {
      "type": "feat",
      "section": "✨ Features"
    },
    {
      "type": "fix",
      "section": "🐛 Fixes"
    },
    {
      "type": "perf",
      "section": "⚡ Performance"
    },
    {
      "type": "refactor",
      "section": "♻️ Refactors"
    },
    {
      "type": "docs",
      "section": "📝 Documentation"
    },
    {
      "type": "test",
      "section": "✅ Tests"
    },
    {
      "type": "build",
      "section": "📦 Build"
    },
    {
      "type": "ci",
      "section": "🤖 CI"
    },
    {
      "type": "deps",
      "section": "⬆️ Dependencies"
    },
    {
      "type": "chore",
      "section": "🧰 Chores"
    }
  ],
  "packages": {
    ".": {
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "initial-version": "0.0.0"
    }
  }
}
